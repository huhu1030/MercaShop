{
  "name": "@mercashop/api",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "concurrently \"tsoa spec-and-routes\" \"tsx watch src/index.ts\"",
    "build": "tsoa spec-and-routes && tsc",
    "start": "node dist/index.js",
    "generate:spec": "tsoa spec",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "jest"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@mercashop/shared": "workspace:*",
    "@mollie/api-client": "^4.0.0",
    "@tsoa/runtime": "^6.6.0",
    "cors": "^2.8.0",
    "dotenv": "^17.3.0",
    "email-templates": "^13.0.0",
    "express": "^4.18.0",
    "firebase-admin": "^12.0.0",
    "google-auth-library": "^10.6.1",
    "helmet": "^8.1.0",
    "mongoose": "^8.0.0",
    "multer": "^1.4.0",
    "nodemailer": "^6.9.0",
    "pug": "^3.0.0",
    "socket.io": "^4.7.0",
    "swagger-ui-express": "^5.0.0",
    "tsoa": "^6.1.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/multer": "^1.4.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/supertest": "^6.0.0",
    "@types/swagger-ui-express": "^4.1.0",
    "concurrently": "^9.2.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
