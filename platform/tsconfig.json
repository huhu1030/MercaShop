{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@tractafleet/shared": ["./packages/shared/src/index.ts"],
      "@tractafleet/shared/*": ["./packages/shared/src/*"]
    },
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.tsbuildinfo"
  },
  "include": ["src", "packages/shared/src"],
  "exclude": ["node_modules", "dist", "**/apis/**"]
}
