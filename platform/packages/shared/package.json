{
  "name": "@mercashop/shared",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/ --ignore-pattern src/generated/",
    "typecheck": "tsc --noEmit",
    "generate:client": "openapi-generator-cli generate -i ../api/dist/swagger.json -g typescript-fetch -o src/generated/api-client --additional-properties=typescriptThreePlus=true,supportsES6=true"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@openapitools/openapi-generator-cli": "^2.13.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0"
  }
}
