{
  "name": "@mercashop/shared",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./api-client": {
      "types": "./src/api/index.ts",
      "default": "./src/api/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "gen-api": "openapi-generator-cli generate -i ../../apps/api/dist/swagger.json -g typescript-axios -o ./src/apis/api -c .openapi-generator-config.json -p withSeparateModelsAndApi=true -p modelPackage=models -p apiPackage=apis -p unwrapResponseData=true"
  },
  "dependencies": {
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.13.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.57.0"
  }
}
