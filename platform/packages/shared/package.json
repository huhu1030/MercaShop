{
  "name": "@mercashop/shared",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./api-client": {
      "types": "./dist/generated/api-client/index.d.ts",
      "default": "./dist/generated/api-client/index.js"
    }
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.generated.json",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "generate:client": "openapi-generator-cli generate -i ../../apps/api/dist/swagger.json -g typescript-fetch -o src/generated/api-client --additional-properties=typescriptThreePlus=true,supportsES6=true"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.13.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.57.0"
  }
}
